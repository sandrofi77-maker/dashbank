# Frontend Environment Variables

# REACT_APP_API_URL: The URL of the API the frontend will connect to
REACT_APP_API_URL=https://api.example.com

# REACT_APP_AUTH_TOKEN: Token for authentication
REACT_APP_AUTH_TOKEN=your_auth_token_here

# REACT_APP_OTHER_VARIABLE: Another variable you might need
REACT_APP_OTHER_VARIABLE=some_value
